@inject HttpClient Http
@using RevolutionaryWebApp.Shared
@using RevolutionaryWebApp.Shared.Models
@using SharedBase.Utilities

@inherits PaginatedPage<EmailBounceDTO>

<PaginatedTable ShowPaginator="@(Data != null)"
                CurrentPage="@Data?.CurrentPage"
                PageCount="@Data?.PageCount"
                OnPageChanged="async e => await ChangePage(e)"
                OnSortChanged="async column => await ChangeSort(column)"
                GetSortClass="@SortClass"
                ShowContentSpinner="@VisibleFetchInProgress"
                Columns="@columns"
                ShowNoContent="@NoItemsFound">
    @if (Data != null)
    {
        @foreach (var item in Data.Results)
        {
            <tr @key="item.Id">
                <th scope="row">@item.Id</th>
                <td>@item.Email.Truncate(40)</td>
                <td>@item.OutstandingBounces</td>
                <td>@item.FirstBounceUtc.ToLocalTime().ToString("G")</td>
                <td>@item.LastBounceUtc.ToLocalTime().ToString("G")</td>
                <td>@(item.DisabledBySystem ? "Yes" : "No")</td>
                <td>@item.BackoffWeeks</td>
                <td>
                    <Button ButtonStyle="secondary" OnPressed="() => ToggleExpanded(item.Id)">
                        @(expandedRow == item.Id ? "Hide" : "Details")
                    </Button>
                </td>
            </tr>
            @if (expandedRow == item.Id)
            {
                <tr class="table-secondary">
                    <td colspan="8">
                        <div>
                            <strong>Email:</strong> @item.Email
                        </div>
                        <div>
                            <strong>Normalized:</strong> @item.NormalizedEmail
                        </div>
                        <div>
                            <strong>First bounce (UTC):</strong> @item.FirstBounceUtc.ToString("u")
                        </div>
                        <div>
                            <strong>Last bounce (UTC):</strong> @item.LastBounceUtc.ToString("u")
                        </div>
                    </td>
                </tr>
            }
        }
    }
</PaginatedTable>

@code {
    private long? expandedRow;

    private readonly List<TableColumn> columns = new()
    {
        new TableColumn("Id", true),
        new TableColumn("Email", false, "Email"),
        new TableColumn("Outstanding", true, "OutstandingBounces"),
        new TableColumn("First", true, "FirstBounceUtc"),
        new TableColumn("Last", true, "LastBounceUtc"),
        new TableColumn("System Disabled", true, "DisabledBySystem"),
        new TableColumn("Backoff (w)", true, "BackoffWeeks"),
        new TableColumn("", false),
    };

    public EmailBounceList() : base(new SortHelper("LastBounceUtc", SortDirection.Descending))
    {
    }

    protected override Task<PagedResult<EmailBounceDTO>?> StartQuery(Dictionary<string, string?> requestParams)
    {
        return Http.GetFromJsonAsync<PagedResult<EmailBounceDTO>>(
            QueryHelpers.AddQueryString("api/v1/EmailBounces", requestParams));
    }

    private void ToggleExpanded(long id)
    {
        expandedRow = expandedRow == id ? null : id;
    }
}
