@using RevolutionaryWebApp.Shared
@using RevolutionaryWebApp.Shared.Forms
@using RevolutionaryWebApp.Client.Services
@inject HttpClient Http
@inject ICSRFTokenReader CSRF

<hr />
<h3>Create an account</h3>

<StatusMessageShower Message="@statusMessage" Type="@statusType" />

<EditForm Model="model" OnValidSubmit="StartSignupAsync">
    <DataAnnotationsValidator />
    <div class="mb-3">
        <InputText type="email" class="form-control" placeholder="email" @bind-Value="model.Email" />
        <ValidationMessage For="() => model.Email" />
    </div>
    <Button class="my-1" type="submit" Enabled="!busy" Spinner="@busy">
        Continue
    </Button>

    <p class="form-text">
        We will send you a link to complete creating your account. Sign up emails expire after 3 days.
    </p>
    <input type="hidden" @bind-value="model.CSRF" />
</EditForm>

@code {
    private SignupStartRequest model = new() { CSRF = string.Empty };
    private bool busy;
    private string? statusMessage;
    private SiteNoticeType statusType = SiteNoticeType.Info;

    private async Task StartSignupAsync()
    {
        busy = true;
        statusMessage = "Sending email...";
        statusType = SiteNoticeType.Info;
        StateHasChanged();

        try
        {
            var content = new Dictionary<string, string>
            {
                [nameof(SignupStartRequest.Email)] = model.Email,
                [nameof(SignupStartRequest.CSRF)] = CSRF.Token,
            };

            using var form = new FormUrlEncodedContent(content);
            var response = await Http.PostAsync("api/v1/signups/start", form);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Check your inbox for a link to complete signup.";
                statusType = SiteNoticeType.Success;
            }
            else
            {
                var text = await response.Content.ReadAsStringAsync();
                statusMessage = string.IsNullOrWhiteSpace(text) ? "Failed to start signup" : text;
                statusType = SiteNoticeType.Danger;
            }
        }
        catch (Exception e)
        {
            statusMessage = "Network request failed: " + e.Message;
            statusType = SiteNoticeType.Danger;
        }
        finally
        {
            busy = false;
            StateHasChanged();
        }
    }
}
