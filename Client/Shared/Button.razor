@if (HasCallback)
{
    <button id="@id" class="@OurClass()" aria-disabled="@Disabled" disabled="@Disabled"
            type="@type" @onclick="PressDetected" @onclick:preventDefault="true">
        @if (Spinner)
        {
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        }
        @ChildContent
    </button>
}
else
{
    <button id="@id" class="@OurClass()" aria-disabled="@Disabled" disabled="@Disabled" type="@type">
        @if (Spinner)
        {
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        }
        @ChildContent
    </button>
}

@code {

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string ButtonStyle { get; set; } = "primary";

    [Parameter]
    public bool Enabled { get; set; } = true;

    [Parameter]
    public bool Small { get; set; }

    [Parameter]
    public bool Spinner { get; set; }

    // Forwarding normal HTML stuff

    [Parameter]
    // ReSharper disable InconsistentNaming
    public string @class { get; set; } = "";

    [Parameter]
    public string type { get; set; } = "button";

    [Parameter]
    public string? id { get; set; }

    // ReSharper restore InconsistentNaming

    [Parameter]
    public EventCallback OnPressed { get; set; }

    [CascadingParameter]
    private EditContext? EditContext { get; set; }

    public bool Disabled => !Enabled;

    private bool HasCallback => OnPressed.HasDelegate;

    private async Task PressDetected()
    {
        if (!Enabled)
            return;

        // If this is a submit-button inside an EditForm, perform validation first
        // and only proceed when the form is valid. This keeps the manual callback
        // pattern while enforcing form validation.
        if (type == "submit" && EditContext is not null)
        {
            var valid = EditContext.Validate();
            if (!valid)
            {
                Console.WriteLine("Cannot submit a form with invalid fields, skipping");

#if DEBUG
                Console.WriteLine("Validation errors:");
                foreach (var error in EditContext.GetValidationMessages())
                {
                    Console.WriteLine(error);
                }

#endif
                return;
            }
        }

        if (HasCallback)
            await OnPressed.InvokeAsync();
    }

    private string OurClass()
    {
        if (Small)
        {
            return $"btn btn-{ButtonStyle} btn-sm {@class}";
        }
        else
        {
            return $"btn btn-{ButtonStyle} {@class}";
        }
    }

}
