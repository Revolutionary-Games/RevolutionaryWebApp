@page "/reset-password/{Token}"

@using RevolutionaryWebApp.Shared
@using RevolutionaryWebApp.Shared.Forms
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Reset password</h3>

<StatusMessageShower Message="@statusMessage" Type="@statusType" />

<EditForm Model="model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="form-group">
        <label for="password">New password</label>
        <InputText id="password" type="password" class="form-control" @bind-Value="model.Password" />
        <small class="form-text text-muted">
            Password must be between @AppInfo.MinPasswordLength and @AppInfo.MaxPasswordLength characters.
        </small>
        <ValidationMessage For="() => model.Password" />
    </div>

    <div class="form-group">
        <label for="password2">Confirm new password</label>
        <InputText id="password2" type="password" class="form-control" @bind-Value="confirmPassword" />
        @if (!string.IsNullOrEmpty(confirmPassword) && confirmPassword != model.Password)
        {
            <div class="text-danger">Passwords do not match.</div>
        }
    </div>

    <Button type="submit" class="mt-1" ButtonStyle="btn btn-primary" Spinner="@busy" Enabled="@(!busy && !success)">
        Reset Password
    </Button>
</EditForm>

<div class="mt-3 text-muted">
    After a successful reset you can log in using your new password.
    You may also want to check the active sessions on your profile page to make sure there are no suspicious active logins.
    @if (success)
    {
        <div class="mt-2">
            <a class="btn btn-success" href="@Nav.GetLinkToLogin()">Go to login</a>
        </div>
    }
    else
    {
        <div class="mt-2">
            <a href="@Nav.GetLinkToLogin()">Go to login</a>
        </div>
    }
</div>

@code {
    private ResetPasswordRequest model = new();
    private string confirmPassword = string.Empty;
    private bool busy;
    private bool success;
    private string? statusMessage;
    private SiteNoticeType statusType = SiteNoticeType.Info;

    [Parameter]
    public string? Token { get; set; }

    protected override void OnParametersSet()
    {
        // Ensure token is propagated to the model for submission
        if (!string.IsNullOrWhiteSpace(Token))
            model.Token = Token;
    }

    private async Task OnSubmit()
    {
        if (string.IsNullOrWhiteSpace(model.Token))
        {
            statusMessage = "Invalid or missing token.";
            statusType = SiteNoticeType.Danger;
            return;
        }

        if (confirmPassword != model.Password)
        {
            statusMessage = "Passwords do not match.";
            statusType = SiteNoticeType.Danger;
            return;
        }

        busy = true;
        statusMessage = null;
        statusType = SiteNoticeType.Info;
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync("api/v1/password/reset", model);
            if (response.IsSuccessStatusCode)
            {
                success = true;
                statusMessage = "Password reset successfully. You can now log in with your new password.";
                statusType = SiteNoticeType.Success;
            }
            else
            {
                var text = await response.Content.ReadAsStringAsync();
                statusMessage = string.IsNullOrEmpty(text) ? "Failed to reset password" : text;
                statusType = SiteNoticeType.Danger;
            }
        }
        catch (Exception e)
        {
            statusMessage = "Failed: " + e.Message;
            statusType = SiteNoticeType.Danger;
        }
        finally
        {
            busy = false;
            StateHasChanged();
        }
    }
}
