@using RevolutionaryWebApp.Shared
@using RevolutionaryWebApp.Shared.Forms
@inject HttpClient Http
@inject Services.ICSRFTokenReader CSRF
@page "/forgot-password"

<h2>Forgot your password?</h2>

<StatusMessageShower Message="@statusMessage" Type="@statusType" />

<EditForm Model="model" OnValidSubmit="RequestResetAsync">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label" for="emailInput">Email address</label>
        <InputText type="email" id="emailInput" class="form-control" placeholder="you@example.com" @bind-Value="model.Email" />
        <ValidationMessage For="() => model.Email" />
    </div>

    <Button class="my-1" type="submit" Enabled="@(!busy)" Spinner="@busy">Request password reset</Button>
    <input type="hidden" @bind-value="model.CSRF" />
</EditForm>

<div class="mt-3 alert alert-warning">
    <strong>Note:</strong> If you have disabled all emails in your preferences, you may not receive the reset email.
    To re-enable important emails, send a new email with the subject line <code>resume email</code> to the website notifications address.
    After that, try requesting a reset again.
</div>

@code {
    private ForgotPasswordRequest model = new() { CSRF = string.Empty };
    private bool busy;

    private string? statusMessage;
    private SiteNoticeType statusType = SiteNoticeType.Info;

    private async Task RequestResetAsync()
    {
        busy = true;
        statusMessage = null;
        statusType = SiteNoticeType.Info;
        StateHasChanged();

        try
        {
            var content = new Dictionary<string, string>
            {
                [nameof(ForgotPasswordRequest.Email)] = model.Email,
                [nameof(ForgotPasswordRequest.CSRF)] = CSRF.Token,
            };

            using var form = new FormUrlEncodedContent(content);
            var response = await Http.PostAsync("api/v1/password/forgot", form);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "If there is an account associated with that email, we have sent password reset instructions.";
                statusType = SiteNoticeType.Success;
            }
            else if ((int)response.StatusCode == 403)
            {
                statusMessage = "You are already logged in. Please log out before requesting a password reset.";
                statusType = SiteNoticeType.Warning;
            }
            else
            {
                var text = await response.Content.ReadAsStringAsync();
                statusMessage = string.IsNullOrWhiteSpace(text) ? "Request failed" : text;
                statusType = SiteNoticeType.Danger;
            }
        }
        catch (Exception e)
        {
            statusMessage = "Network request failed: " + e.Message;
            statusType = SiteNoticeType.Danger;
        }
        finally
        {
            busy = false;
            StateHasChanged();
        }
    }
}
